{
  "rules": [
    {
      "id": "R001", "group": "power_startup", "priority": 3, "cf": 0.85,
      "name": "Adapter hỏng — đèn pin đỏ + không sạc",
      "conditions": ["no_power", "battery_indicator_red", "is_laptop"],
      "adds_facts": ["probable_adapter_issue"]
    },
    {
      "id": "R002", "group": "power_startup", "priority": 4, "cf": 0.90,
      "name": "Xác nhận Adapter hỏng",
      "conditions": ["probable_adapter_issue", "no_charge"],
      "triggers_diagnosis": "DIAG_PWR_01"
    },
    {
      "id": "R003", "group": "power_startup", "priority": 3, "cf": 0.85,
      "name": "Pin chai — chỉ chạy khi cắm điện",
      "conditions": ["power_led_on", "laptop_only_on_adapter", "is_laptop"],
      "not_conditions": ["no_charge"],
      "triggers_diagnosis": "DIAG_PWR_02"
    },
    {
      "id": "R004", "group": "power_startup", "priority": 3, "cf": 0.80,
      "name": "PSU Desktop hỏng — không điện",
      "conditions": ["no_power", "is_desktop"],
      "not_conditions": ["power_led_on"],
      "adds_facts": ["probable_power_hardware"]
    },
    {
      "id": "R005", "group": "power_startup", "priority": 3, "cf": 0.85,
      "name": "Xác nhận PSU hỏng",
      "conditions": ["probable_power_hardware"],
      "not_conditions": ["power_led_on"],
      "triggers_diagnosis": "DIAG_PWR_03"
    },
    {
      "id": "R006", "group": "power_startup", "priority": 2, "cf": 0.75,
      "name": "Bo mạch chủ lỗi điện (PSU test OK nhưng có điện, quạt không quay)",
      "conditions": ["probable_power_hardware", "power_led_on", "fan_not_spinning"],
      "_note": "fan_not_spinning được set bởi Q02-A — bật máy hoàn toàn không có phản ứng",
      "triggers_diagnosis": "DIAG_PWR_04"
    },
    {
      "id": "R007", "group": "power_startup", "priority": 4, "cf": 0.90,
      "name": "POST thất bại — nhiều beep",
      "conditions": ["multiple_beeps", "power_led_on", "fan_spinning"],
      "adds_facts": ["bios_post_fail"]
    },
    {
      "id": "R008", "group": "power_startup", "priority": 3, "cf": 0.80,
      "name": "POST fail — RAM lỏng/hỏng",
      "conditions": ["bios_post_fail", "no_display_after_power"],
      "triggers_diagnosis": "DIAG_PWR_05"
    },
    {
      "id": "R009", "group": "power_startup", "priority": 3, "cf": 0.85,
      "name": "Boot OK nhưng không màn hình",
      "conditions": ["power_led_on", "single_beep", "screen_black"],
      "adds_facts": ["system_boots_no_display"]
    },
    {
      "id": "R010", "group": "power_startup", "priority": 2, "cf": 0.70,
      "name": "Không sạc — có thể lỗi cổng sạc",
      "conditions": ["no_charge", "battery_indicator_red"],
      "not_conditions": ["laptop_only_on_adapter"],
      "triggers_diagnosis": "DIAG_PWR_01"
    },
    {
      "id": "R_Q08_PSU", "group": "power_startup", "priority": 4, "cf": 0.87,
      "name": "Ổ điện OK + Đèn MOBO tắt + PSU chưa xác nhận tốt → PSU hỏng",
      "conditions": ["power_outlet_ok", "no_mobo_led", "no_power"],
      "not_conditions": ["psu_tested_ok"],
      "triggers_diagnosis": "DIAG_PWR_03"
    },
    {
      "id": "R_Q08_MOBO", "group": "power_startup", "priority": 5, "cf": 0.90,
      "name": "Ổ điện OK + PSU đã test tốt + MOBO không LED → Mobo lỗi",
      "conditions": ["power_outlet_ok", "no_mobo_led", "psu_tested_ok", "no_power"],
      "triggers_diagnosis": "DIAG_PWR_04"
    },
    {
      "id": "R016", "group": "display", "priority": 4, "cf": 0.90,
      "name": "Đen + màn ngoài OK — lỗi màn nội bộ",
      "conditions": ["system_boots_no_display", "external_monitor_ok"],
      "adds_facts": ["display_hardware_issue"]
    },
    {
      "id": "R017", "group": "display", "priority": 2, "cf": 0.75,
      "name": "Lỗi màn nội bộ — cáp màn hình lỏng",
      "conditions": ["display_hardware_issue"],
      "not_conditions": ["screen_lines", "screen_color_distorted"],
      "triggers_diagnosis": "DIAG_DSP_01"
    },
    {
      "id": "R018", "group": "display", "priority": 3, "cf": 0.85,
      "name": "Lỗi màn nội bộ + sọc — panel LCD hỏng",
      "conditions": ["display_hardware_issue", "screen_lines"],
      "triggers_diagnosis": "DIAG_DSP_03"
    },
    {
      "id": "R019", "group": "display", "priority": 3, "cf": 0.85,
      "name": "Màn ngoài cũng lỗi — GPU/Driver",
      "conditions": ["screen_black", "external_monitor_same_issue"],
      "adds_facts": ["probable_gpu_issue"]
    },
    {
      "id": "R020", "group": "display", "priority": 4, "cf": 0.90,
      "name": "GPU issue + driver mới — lỗi driver GPU",
      "conditions": ["probable_gpu_issue", "display_after_driver_install"],
      "triggers_diagnosis": "DIAG_DSP_02"
    },
    {
      "id": "R021", "group": "display", "priority": 3, "cf": 0.80,
      "name": "GPU issue + màu sai + không driver mới — GPU hardware",
      "conditions": ["probable_gpu_issue", "screen_color_distorted"],
      "not_conditions": ["display_after_driver_install"],
      "triggers_diagnosis": "DIAG_DSP_04"
    },
    {
      "id": "R022", "group": "display", "priority": 3, "cf": 0.85,
      "name": "Nhấp nháy + sau driver update",
      "conditions": ["screen_flickering", "display_after_driver_install"],
      "triggers_diagnosis": "DIAG_DSP_02"
    },
    {
      "id": "R023", "group": "display", "priority": 3, "cf": 0.80,
      "name": "Màn trắng — panel lỗi",
      "conditions": ["screen_white"],
      "not_conditions": ["external_monitor_same_issue"],
      "triggers_diagnosis": "DIAG_DSP_03"
    },
    {
      "id": "R024", "group": "display", "priority": 3, "cf": 0.85,
      "name": "Độ sáng thấp — cài đặt brightness",
      "conditions": ["brightness_too_low"],
      "not_conditions": ["screen_lines", "screen_flickering"],
      "triggers_diagnosis": "DIAG_DSP_05"
    },
    {
      "id": "R025", "group": "display", "priority": 3, "cf": 0.80,
      "name": "Nhìn nghiêng thấy hình — backlight hỏng",
      "conditions": ["brightness_too_low", "backlight_fail"],
      "triggers_diagnosis": "DIAG_DSP_03"
    },
    {
      "id": "R026", "group": "display", "priority": 5, "cf": 0.95,
      "name": "Va đập + sọc — vỡ panel",
      "conditions": ["screen_lines", "physical_impact_suspected"],
      "triggers_diagnosis": "DIAG_DSP_03"
    },
    {
      "id": "R029", "group": "os_boot", "priority": 3, "cf": 0.85,
      "name": "BSOD + memory error — lỗi RAM",
      "conditions": ["bsod_appears", "bsod_memory_error"],
      "adds_facts": ["ram_related_bsod"]
    },
    {
      "id": "R030", "group": "os_boot", "priority": 3, "cf": 0.85,
      "name": "RAM lỗi không từ driver — faulty RAM",
      "conditions": ["ram_related_bsod"],
      "not_conditions": ["recent_driver_update"],
      "triggers_diagnosis": "DIAG_OS_03"
    },
    {
      "id": "R031", "group": "os_boot", "priority": 2, "cf": 0.75,
      "name": "RAM lỗi + driver update — có thể driver gây BSOD memory",
      "conditions": ["ram_related_bsod", "recent_driver_update"],
      "adds_facts": ["driver_related_bsod"]
    },
    {
      "id": "R032", "group": "os_boot", "priority": 4, "cf": 0.90,
      "name": "BSOD + driver error code",
      "conditions": ["bsod_appears", "bsod_driver_error"],
      "adds_facts": ["driver_related_bsod"]
    },
    {
      "id": "R033", "group": "os_boot", "priority": 4, "cf": 0.90,
      "name": "Driver BSOD + thay đổi gần đây",
      "conditions": ["driver_related_bsod", "recent_change_caused_issue"],
      "triggers_diagnosis": "DIAG_OS_02"
    },
    {
      "id": "R034", "group": "os_boot", "priority": 2, "cf": 0.75,
      "name": "Driver BSOD + không thay đổi — file hệ thống",
      "conditions": ["driver_related_bsod"],
      "not_conditions": ["recent_change_caused_issue"],
      "triggers_diagnosis": "DIAG_OS_01"
    },
    {
      "id": "R035", "group": "os_boot", "priority": 4, "cf": 0.90,
      "name": "BSOD + disk error code",
      "conditions": ["bsod_appears", "bsod_disk_error"],
      "adds_facts": ["disk_related_bsod"]
    },
    {
      "id": "R036", "group": "os_boot", "priority": 3, "cf": 0.85,
      "name": "Disk BSOD — HDD/SSD lỗi",
      "conditions": ["disk_related_bsod"],
      "triggers_diagnosis": "DIAG_OS_04"
    },
    {
      "id": "R037", "group": "os_boot", "priority": 4, "cf": 0.90,
      "name": "Boot loop + Windows Update — update gây lỗi",
      "conditions": ["boot_loop", "recent_windows_update"],
      "triggers_diagnosis": "DIAG_OS_05"
    },
    {
      "id": "R038", "group": "os_boot", "priority": 3, "cf": 0.80,
      "name": "Boot loop không update — MBR hỏng",
      "conditions": ["boot_loop"],
      "not_conditions": ["recent_windows_update", "recent_software_install"],
      "triggers_diagnosis": "DIAG_OS_06"
    },
    {
      "id": "R039", "group": "os_boot", "priority": 3, "cf": 0.80,
      "name": "Dừng logo + Safe Mode OK — driver startup lỗi",
      "conditions": ["stuck_at_logo", "safe_mode_works"],
      "triggers_diagnosis": "DIAG_OS_02"
    },
    {
      "id": "R040", "group": "os_boot", "priority": 3, "cf": 0.85,
      "name": "Dừng logo + Safe Mode fail — OS hỏng nghiêm trọng",
      "conditions": ["stuck_at_logo", "safe_mode_fails"],
      "triggers_diagnosis": "DIAG_OS_01"
    },
    {
      "id": "R041", "group": "os_boot", "priority": 3, "cf": 0.85,
      "name": "Windows không load + Safe Mode fail — MBR",
      "conditions": ["windows_not_loading", "safe_mode_fails"],
      "not_conditions": ["recent_change_caused_issue"],
      "triggers_diagnosis": "DIAG_OS_06"
    },
    {
      "id": "R042", "group": "os_boot", "priority": 2, "cf": 0.75,
      "name": "Treo random + thay đổi gần đây — software conflict",
      "conditions": ["os_freezes_randomly", "recent_change_caused_issue"],
      "triggers_diagnosis": "DIAG_OS_02"
    },
    {
      "id": "R044", "group": "os_boot", "priority": 3, "cf": 0.85,
      "name": "SFC lỗi + treo — file hệ thống hỏng",
      "conditions": ["sfc_errors_found", "os_freezes_randomly"],
      "triggers_diagnosis": "DIAG_OS_01"
    },
    {
      "id": "R049", "group": "network", "priority": 4, "cf": 0.90,
      "name": "Không thấy Wi-Fi + không có adapter — adapter hardware hỏng",
      "conditions": ["wifi_not_visible", "wifi_adapter_missing"],
      "triggers_diagnosis": "DIAG_NET_02"
    },
    {
      "id": "R050", "group": "network", "priority": 3, "cf": 0.85,
      "name": "Không thấy Wi-Fi + có adapter — lỗi driver",
      "conditions": ["wifi_not_visible"],
      "not_conditions": ["wifi_adapter_missing"],
      "adds_facts": ["probable_wifi_driver_issue"]
    },
    {
      "id": "R051", "group": "network", "priority": 3, "cf": 0.85,
      "name": "Driver Wi-Fi lỗi — chẩn đoán",
      "conditions": ["probable_wifi_driver_issue"],
      "triggers_diagnosis": "DIAG_NET_01"
    },
    {
      "id": "R052", "group": "network", "priority": 3, "cf": 0.85,
      "name": "Có Wi-Fi không Internet + thiết bị khác OK — lỗi ở máy này",
      "conditions": ["wifi_connected_no_internet", "other_devices_same_wifi_ok"],
      "adds_facts": ["probable_local_network_config_issue"]
    },
    {
      "id": "R053", "group": "network", "priority": 4, "cf": 0.90,
      "name": "Cấu hình mạng lỗi + DNS error — lỗi DNS",
      "conditions": ["probable_local_network_config_issue", "dns_error_message"],
      "triggers_diagnosis": "DIAG_NET_03"
    },
    {
      "id": "R054", "group": "network", "priority": 4, "cf": 0.90,
      "name": "Cấu hình mạng lỗi + IP conflict",
      "conditions": ["probable_local_network_config_issue", "ip_conflict"],
      "triggers_diagnosis": "DIAG_NET_06"
    },
    {
      "id": "R055", "group": "network", "priority": 3, "cf": 0.85,
      "name": "Cấu hình mạng + cáp LAN cũng lỗi — network stack hỏng",
      "conditions": ["probable_local_network_config_issue", "ethernet_no_internet"],
      "triggers_diagnosis": "DIAG_NET_05"
    },
    {
      "id": "R056", "group": "network", "priority": 4, "cf": 0.90,
      "name": "Wi-Fi + LAN đều lỗi + tất cả thiết bị — router/ISP",
      "conditions": ["wifi_connected_no_internet", "ethernet_no_internet", "other_devices_same_wifi_fail"],
      "triggers_diagnosis": "DIAG_NET_04"
    },
    {
      "id": "R058", "group": "network", "priority": 2, "cf": 0.75,
      "name": "Chỉ một số website — DNS hoặc VPN",
      "conditions": ["specific_sites_blocked"],
      "not_conditions": ["vpn_related"],
      "triggers_diagnosis": "DIAG_NET_03"
    },
    {
      "id": "R060", "group": "network", "priority": 2, "cf": 0.70,
      "name": "Wi-Fi chậm + thiết bị khác OK — driver/adapter",
      "conditions": ["wifi_slow", "other_devices_same_wifi_ok"],
      "triggers_diagnosis": "DIAG_NET_01"
    },
    {
      "id": "R066", "group": "audio_camera", "priority": 3, "cf": 0.85,
      "name": "Không âm thanh + không thấy device — hardware soundcard lỗi",
      "conditions": ["no_sound", "audio_device_missing"],
      "triggers_diagnosis": "DIAG_AUD_03"
    },
    {
      "id": "R067", "group": "audio_camera", "priority": 4, "cf": 0.90,
      "name": "Không âm thanh + driver lỗi",
      "conditions": ["no_sound", "audio_driver_yellow_mark"],
      "triggers_diagnosis": "DIAG_AUD_01"
    },
    {
      "id": "R068", "group": "audio_camera", "priority": 3, "cf": 0.85,
      "name": "Không âm thanh + device bình thường — muted/disabled",
      "conditions": ["no_sound"],
      "not_conditions": ["audio_device_missing", "audio_driver_yellow_mark"],
      "triggers_diagnosis": "DIAG_AUD_02"
    },
    {
      "id": "R069", "group": "audio_camera", "priority": 3, "cf": 0.80,
      "name": "Âm thanh sau restart rồi mất — driver không ổn định",
      "conditions": ["audio_works_after_restart", "no_sound"],
      "triggers_diagnosis": "DIAG_AUD_01"
    },
    {
      "id": "R072", "group": "audio_camera", "priority": 5, "cf": 0.95,
      "name": "Camera bị chặn Privacy",
      "conditions": ["camera_not_detected", "camera_privacy_blocked"],
      "triggers_diagnosis": "DIAG_CAM_01"
    },
    {
      "id": "R073", "group": "audio_camera", "priority": 3, "cf": 0.85,
      "name": "Camera lỗi + không phải privacy — driver",
      "conditions": ["camera_not_detected"],
      "not_conditions": ["camera_privacy_blocked"],
      "triggers_diagnosis": "DIAG_CAM_02"
    },
    {
      "id": "R075", "group": "audio_camera", "priority": 4, "cf": 0.90,
      "name": "Micro disabled trong settings",
      "conditions": ["microphone_not_working", "micro_disabled_in_settings"],
      "triggers_diagnosis": "DIAG_AUD_02"
    },
    {
      "id": "R076", "group": "audio_camera", "priority": 3, "cf": 0.85,
      "name": "Micro lỗi + driver vấn đề",
      "conditions": ["microphone_not_working", "audio_driver_yellow_mark"],
      "triggers_diagnosis": "DIAG_AUD_01"
    },
    {
      "id": "R079", "group": "peripherals", "priority": 4, "cf": 0.90,
      "name": "USB không nhận + 1 cổng + thiết bị OK máy khác — cổng USB hỏng",
      "conditions": ["usb_not_detected", "specific_usb_port_fail", "usb_device_works_on_other_pc"],
      "triggers_diagnosis": "DIAG_PER_01"
    },
    {
      "id": "R080", "group": "peripherals", "priority": 3, "cf": 0.85,
      "name": "USB không nhận + tất cả cổng — USB Controller lỗi",
      "conditions": ["usb_not_detected", "all_usb_ports_fail"],
      "triggers_diagnosis": "DIAG_PER_02"
    },
    {
      "id": "R081", "group": "peripherals", "priority": 4, "cf": 0.90,
      "name": "USB thiết bị lỗi ở mọi nơi — thiết bị hỏng",
      "conditions": ["usb_not_detected", "usb_device_fails_all_ports"],
      "triggers_diagnosis": "DIAG_PER_03"
    },
    {
      "id": "R082", "group": "peripherals", "priority": 3, "cf": 0.85,
      "name": "USB nhận nhưng lỗi + thiết bị OK máy khác — driver",
      "conditions": ["usb_device_error", "usb_device_works_on_other_pc"],
      "triggers_diagnosis": "DIAG_PER_04"
    },
    {
      "id": "R091", "group": "performance", "priority": 4, "cf": 0.90,
      "name": "Quạt ồn + nóng + CPU cao — thermal throttling",
      "conditions": ["fan_very_loud", "laptop_very_hot", "high_cpu_usage"],
      "adds_facts": ["thermal_throttling"]
    },
    {
      "id": "R092", "group": "performance", "priority": 4, "cf": 0.90,
      "name": "Thermal throttling — chẩn đoán quá nhiệt",
      "conditions": ["thermal_throttling"],
      "triggers_diagnosis": "DIAG_PERF_01"
    },
    {
      "id": "R093", "group": "performance", "priority": 5, "cf": 0.95,
      "name": "Thermal + máy cũ + bụi — bụi + keo nhiệt",
      "conditions": ["thermal_throttling", "thermal_paste_old", "dust_in_vents"],
      "triggers_diagnosis": "DIAG_PERF_01"
    },
    {
      "id": "R094", "group": "performance", "priority": 3, "cf": 0.85,
      "name": "CPU cao + malware — malware gây chậm",
      "conditions": ["high_cpu_usage", "malware_suspected"],
      "adds_facts": ["malware_causing_slow"]
    },
    {
      "id": "R095", "group": "performance", "priority": 3, "cf": 0.85,
      "name": "Malware xác nhận",
      "conditions": ["malware_causing_slow"],
      "triggers_diagnosis": "DIAG_PERF_02"
    },
    {
      "id": "R096", "group": "performance", "priority": 4, "cf": 0.90,
      "name": "Boot chậm + nhiều startup",
      "conditions": ["slow_boot_time", "startup_programs_many"],
      "triggers_diagnosis": "DIAG_PERF_03"
    },
    {
      "id": "R097", "group": "performance", "priority": 3, "cf": 0.85,
      "name": "RAM đầy + chậm — RAM không đủ",
      "conditions": ["high_memory_usage", "system_very_slow"],
      "not_conditions": ["thermal_throttling"],
      "triggers_diagnosis": "DIAG_PERF_04"
    },
    {
      "id": "R098", "group": "performance", "priority": 3, "cf": 0.85,
      "name": "Disk 100% + chậm — ổ đĩa bottleneck",
      "conditions": ["high_disk_usage", "system_very_slow"],
      "adds_facts": ["storage_causing_slow"]
    },
    {
      "id": "R099", "group": "performance", "priority": 4, "cf": 0.90,
      "name": "Disk bottleneck + disk đầy",
      "conditions": ["storage_causing_slow", "disk_full"],
      "triggers_diagnosis": "DIAG_STR_01"
    },
    {
      "id": "R100", "group": "performance", "priority": 4, "cf": 0.90,
      "name": "Disk bottleneck + click sound — HDD hỏng",
      "conditions": ["storage_causing_slow", "disk_error_sound"],
      "triggers_diagnosis": "DIAG_STR_02"
    },
    {
      "id": "R106", "group": "storage", "priority": 4, "cf": 0.90,
      "name": "Ổ đĩa đầy + hệ thống chậm",
      "conditions": ["disk_full", "system_very_slow"],
      "triggers_diagnosis": "DIAG_STR_01"
    },
    {
      "id": "R107", "group": "storage", "priority": 4, "cf": 0.90,
      "name": "Click sound + chậm copy — HDD sắp hỏng",
      "conditions": ["disk_error_sound", "slow_file_transfer"],
      "adds_facts": ["hdd_failing"]
    },
    {
      "id": "R108", "group": "storage", "priority": 4, "cf": 0.90,
      "name": "HDD failing — chẩn đoán",
      "conditions": ["hdd_failing"],
      "triggers_diagnosis": "DIAG_STR_02"
    },
    {
      "id": "R109", "group": "storage", "priority": 4, "cf": 0.90,
      "name": "File lỗi + CHKDSK lỗi — file system hỏng",
      "conditions": ["file_corruption", "chkdsk_errors"],
      "triggers_diagnosis": "DIAG_STR_04"
    },
    {
      "id": "R110", "group": "storage", "priority": 3, "cf": 0.85,
      "name": "Bad sectors + file lỗi — HDD hỏng",
      "conditions": ["bad_sectors_detected", "file_corruption"],
      "triggers_diagnosis": "DIAG_STR_02"
    },
    {
      "id": "R111", "group": "storage", "priority": 3, "cf": 0.85,
      "name": "SSD health thấp + chậm",
      "conditions": ["ssd_health_low", "slow_file_transfer"],
      "triggers_diagnosis": "DIAG_STR_03"
